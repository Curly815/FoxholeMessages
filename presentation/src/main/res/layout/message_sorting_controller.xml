<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/preferences"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/autoSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:summary="@string/message_sorting_auto_sort_summary"
            app:title="@string/message_sorting_auto_sort_title"
            app:widget="@layout/settings_switch_widget" />

        <dev.octoshrimpy.quik.common.widget.QkTextView
            style="@style/PreferenceCategory"
            android:text="@string/message_sorting_category_notifications_header" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/notificationsPersonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_notifications_black_24dp"
            app:title="@string/message_sorting_category_personal" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/notificationsPromotional"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_notifications_black_24dp"
            app:title="@string/message_sorting_category_promotional" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/notificationsTransactional"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_notifications_black_24dp"
            app:title="@string/message_sorting_category_transactional" />

        <dev.octoshrimpy.quik.common.widget.QkTextView
            style="@style/PreferenceCategory"
            android:text="@string/message_sorting_category_manage_header" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/senderRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_person_black_24dp"
            app:title="@string/message_sorting_sender_rules_title"
            app:summary="@string/message_sorting_sender_rules_summary" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/trustedSenders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_person_add_black_24dp"
            app:title="@string/message_sorting_trusted_senders_title"
            app:summary="@string/message_sorting_trusted_senders_summary" />

        <dev.octoshrimpy.quik.common.widget.PreferenceView
            android:id="@+id/sortExisting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_sync_black_24dp"
            app:title="@string/message_sorting_sort_existing_title"
            app:summary="@string/message_sorting_sort_existing_summary" />

    </LinearLayout>

</ScrollView>
